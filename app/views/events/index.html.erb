<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">Upcoming Events</h1>

  <div class="grid gap-6">
    <% @events.each do |event| %>
      <%= link_to event_path(event), class: "block bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow" do %>
        <h2 class="text-xl font-semibold text-blue-600"><%= event.title %></h2>
        <p class="text-gray-600 mt-2"><%= truncate(event.description, length: 150) %></p>
        <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
          <span><%= event.date.strftime("%B %d, %Y at %I:%M %p") %></span>
          <span>Capacity: <%= event.capacity %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
